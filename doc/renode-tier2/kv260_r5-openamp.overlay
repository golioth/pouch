/*
 * OpenAMP config for kv260_r5 matching the Renode ZynqMP OpenAMP demo /
 * Linux DTB carve-out: vrings @0x3ed40000/0x3ed44000, rpmsg buffers
 * @0x3ed48000 (1MB). Firmware runs from TCM (board default @0x0); the shared
 * ring/buffer memory lives in DDR.
 */
/ {
	chosen {
		zephyr,ipc_shm = &shram;
		zephyr,ipc = &rpu0_ipi;
	};

	shram: memory@3ed40000 {
		compatible = "mmio-sram";
		reg = <0x3ed40000 0x108000>;
	};
};

&rpu0_ipi {
	status = "okay";
};

/*
 * remoteproc loads the R5 firmware into the DDR rproc carve-out (0x3ed00000,
 * 256K) rather than TCM: the openamp image (~155K) does not fit the 64K TCM
 * that device-address 0x0 maps to. This node is in r5f_0's memory-region, so
 * the Xilinx R5 remoteproc driver maps it.
 */
&sram0 {
	reg = <0x3ed00000 0x40000>;
};

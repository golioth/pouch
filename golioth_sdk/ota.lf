[sections:golioth_ota_registered_component_sections]
entries:
    ._golioth_ota_registered_component.static+

[scheme:golioth_ota_registered_component_iterable]
entries:
    golioth_ota_registered_component_sections -> flash_rodata

[mapping:golioth_ota_registered_component]
archive: *
entries:
    * (golioth_ota_registered_component_iterable);
        golioth_ota_registered_component_sections -> flash_rodata KEEP() SORT(name) SURROUND(golioth_ota_registered_component)



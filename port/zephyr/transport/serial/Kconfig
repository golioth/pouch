menu "Pouch Serial Transport"
    visible if POUCH_TRANSPORT_SERIAL

config POUCH_TRANSPORT_SERIAL_BROKER
    bool
    depends on POUCH_GATEWAY
    default y
    help
        Enable the broker-based implementation of the Pouch Serial transport.

config POUCH_TRANSPORT_SERIAL_DEVICE
    bool
    depends on POUCH
    default y
    help
        Enable the device implementation of the Pouch Serial transport, which
        runs on the node device and communicates with a gateway running the
        broker implementation.

menuconfig POUCH_SPI_DEVICE
    bool "Pouch SPI device transport"
    depends on SPI
    depends on POUCH
    select SPI_ASYNC
    select SPSC_PBUF
    select POUCH_TRANSPORT_SERIAL_DEVICE
    default $(dt_compat_on_bus,$(DT_COMPAT_GOLIOTH_POUCH_DEVICE),spi)
    help
      Enable the SPI slave transport adapter for the Pouch serial
      device protocol.

if POUCH_SPI_DEVICE

config POUCH_SPI_DEVICE_FRAME_SIZE
    int "SPI slave frame size"
    default 128
    range 2 256
    help
      Maximum frame size in bytes for SPI transactions. Controls the
      size of the TX and RX buffers. The first byte is reserved for
      a length field, so the maximum payload is one less than this
      value.

config POUCH_SPI_DEVICE_RX_BUFFER_SIZE
    int "SPI slave RX buffer size"
    default 256
    help
      Size of the RX buffer in bytes for the SPI slave transport adapter.
      Must be at least as large as POUCH_SPI_DEVICE_FRAME_SIZE.

module = POUCH_SPI_DEVICE
module-str = Pouch SPI Slave
source "subsys/logging/Kconfig.template.log_config"

endif # POUCH_SPI_DEVICE

menuconfig POUCH_SPI_BROKER
    bool "Pouch SPI broker transport"
    depends on SPI
    depends on POUCH_GATEWAY
    default $(dt_compat_on_bus,$(DT_COMPAT_GOLIOTH_POUCH_BROKER),spi)
    help
      Enable the SPI broker (master) transport adapter for the Pouch serial
      broker protocol. Each devicetree node with compatible
      "golioth,pouch-broker" on an SPI bus creates a broker instance.

if POUCH_SPI_BROKER

config POUCH_SPI_BROKER_FRAME_SIZE
    int "SPI broker frame size"
    default 128
    range 2 256
    help
      Maximum frame size in bytes for SPI transactions. Controls the
      size of the TX and RX buffers. The first byte is reserved for
      a length field, so the maximum payload is one less than this
      value.

config POUCH_SPI_BROKER_THREAD_STACK_SIZE
    int "SPI broker work queue thread stack size"
    default 1200
    help
      Stack size in bytes for the shared SPI broker work queue thread.

config POUCH_SPI_BROKER_INTERFRAME_DELAY
    int "Delay between each frame in milliseconds"
    default 5
    help
      Time in milliseconds to wait between frames, to allow the SPI slave to
      set up its SPI buffers.

module = POUCH_SPI_BROKER
module-str = Pouch SPI Broker
source "subsys/logging/Kconfig.template.log_config"

endif # POUCH_SPI_BROKER

config POUCH_UART
    bool # Invisible symbol enabling the common UART transport implementation

config POUCH_UART_DEVICE
    bool "Pouch UART device transport"
    depends on SERIAL
    depends on POUCH
    select POUCH_UART
    select UART_ASYNC_API
    select POUCH_TRANSPORT_SERIAL_DEVICE
    default $(dt_compat_on_bus,$(DT_COMPAT_GOLIOTH_POUCH_DEVICE),uart)
    help
      Enable the UART transport adapter for the Pouch serial device
      protocol. The device runs on the node and communicates with a
      broker over a point-to-point UART link.

if POUCH_UART_DEVICE

module = POUCH_UART_DEVICE
module-str = Pouch UART Device
source "subsys/logging/Kconfig.template.log_config"

endif

config POUCH_UART_BROKER
    bool "Pouch UART broker transport"
    depends on SERIAL
    depends on POUCH_GATEWAY
    select POUCH_UART
    select UART_ASYNC_API
    default $(dt_compat_on_bus,$(DT_COMPAT_GOLIOTH_POUCH_BROKER),uart)
    help
      Enable the UART transport adapter for the Pouch serial broker
      protocol. The broker runs on the gateway and drives the exchange
      sequence with a device over a point-to-point UART link.

if POUCH_UART_BROKER

module = POUCH_UART_BROKER
module-str = Pouch UART Broker
source "subsys/logging/Kconfig.template.log_config"

endif # POUCH_UART_BROKER

if POUCH_UART

config POUCH_UART_FRAME_SIZE
    int "UART max frame size"
    default 255
    range 2 255
    help
      Maximum payload size in bytes for a single UART frame.

config POUCH_UART_INTERFRAME_DELAY
    int "Delay between each frame in milliseconds"
    default 5
    help
      Time in milliseconds to wait between transmitted frames, to allow
      the other device to set up its buffers.

module = POUCH_UART
module-str = Pouch UART common
source "subsys/logging/Kconfig.template.log_config"

endif # POUCH_UART

module = POUCH_SERIAL
module-str = Pouch Serial Transport
source "subsys/logging/Kconfig.template.log_config"

endmenu

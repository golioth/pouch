CONFIG_ESP_MAIN_TASK_STACK_SIZE=5500
CONFIG_POUCH_THREAD_STACK_SIZE=3328
CONFIG_POUCH_UPLINK_PROCESSING_STACK_SIZE=1792
CONFIG_LOG_TIMESTAMP_SOURCE_SYSTEM=y

# Pouch
CONFIG_POUCH=y
CONFIG_POUCH_TRANSPORT_HTTP_CLIENT=y
CONFIG_GOLIOTH=y
CONFIG_GOLIOTH_OTA=y
CONFIG_GOLIOTH_SETTINGS=y

# Flash size
CONFIG_PARTITION_TABLE_TWO_OTA_LARGE=y
CONFIG_ESPTOOLPY_FLASHSIZE_8MB=y

# Application Version
CONFIG_APP_PROJECT_VER_FROM_CONFIG=y
CONFIG_APP_PROJECT_VER="1.0.0"

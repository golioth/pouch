config NCS_APPLICATION_BOOT_BANNER_STRING
    string
    default "Pouch BLE GATT Example"

source "$ZEPHYR_BASE/Kconfig"

config EXAMPLE_SYNC_PERIOD_S
    int "Sync Period"
    default 20
    help
      The time, in seconds, after a sync to wait before requesting a sync from
      a gateway.

config EXAMPLE_CREDENTIALS_DIR
    string "Directory containing credentials"
    default "/lfs1/credentials"
    help
      Directory on mounted file system containing credentials.

config EXAMPLE_POUCH_DEVICE_CRT_FILENAME
    string "Pouch device crt filename in filesystem"
    default "crt.der"
    help
      The filename used to store the pouch device certificate in the filesystem.

config EXAMPLE_POUCH_DEVICE_KEY_FILENAME
    string "Pouch device key filename in filesystem"
    default "key.der"
    help
      The filename used to store the pouch device private key in the filesystem.

config EXAMPLE_FW_UPDATE_COMPONENT
    string "OTA component to use for firmware update"
    default "ble_gatt_example"
    help
      Name of component in OTA manifest to use for firmware update.

choice EXAMPLE_FW_UPDATE_MODE
    prompt "Firmware update mode"
    depends on GOLIOTH_OTA
    default EXAMPLE_FW_UPDATE_FLASH

config EXAMPLE_FW_UPDATE_FLASH
    bool "Normal (write to flash)"
    help
        OTA component data is written to flash and mcuboot upgrade is requested.

config EXAMPLE_FW_UPDATE_SHA256_VERIFY
    bool "Download only and verify SHA256"
    help
        OTA component data is hashed with SHA256 instead of written
        to flash. The resulting hash is logged to the console for verification.

endchoice

# This option is used only for automated tests
config EXAMPLE_BT_AUTO_CONFIRM
	bool
	default y if BOARD_NRF52_BSIM_NATIVE

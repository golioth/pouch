 *
 * uart0 stays the console; uart1 carries the Pouch serial link on its own pty,
 * which the broker process attaches to.
 */

/ {
	chosen {
		golioth,pouch-serial-uart = &uart1;
	};
};

&uart1 {
	status = "okay";
};
